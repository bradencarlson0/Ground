        "market_value_live": ["currValMarket", "CURRVALMARKET"],
        "land_value_live": ["currValLand", "CURRVALLAND"],
        "improvement_value_live": ["currValImprv", "CURRVALIMPRV"],
        "improvement_sqft_live": ["imprvMainArea", "IMPRVMAINAREA"],
        "year_built_live": ["imprvYearBuilt", "IMPRVYEARBUILT"],
        "cad_acres_live": ["landSizeAcres", "LANDSIZEACRES"],
        "cad_land_sqft_live": ["landSizeSqft", "LANDSIZESQFT"],
        "cad_use_code_live": ["propUseCode", "PROPUSECODE"],
        "cad_property_type_live": ["propType", "PROPTYPE"],
        "homestead_flag_live": ["exemptHmstdFlag", "EXEMPTHMSTDFLAG"],
        "cad_data_date": ["dataDate", "DATADATE"],
    }.items():
        coalesce_column(target, collin, candidates)

    # Denton fields.
    for target, candidates in {
        "owner_name_live": ["name", "ownername"],
        "situs_address_live": ["situs", "situsaddress", "situsfulladdress"],
        "legal_description_live": ["legaldescription"],
        "market_value_live": ["ownerMarketValue", "marketvalue", "totalvalue"],
        "land_value_live": ["landvalue"],
        "improvement_value_live": ["improvementvalue", "imprvalue", "improvementmarketvalue"],
        "improvement_sqft_live": ["improvementarea", "improvementsqft", "buildingarea"],
        "year_built_live": ["yearbuilt"],
        "cad_acres_live": ["legalacreage", "effectivesizeacres"],
        "cad_land_sqft_live": ["land_sqft", "landsqft"],
        "cad_use_code_live": ["usecd", "usecode"],
        "cad_property_type_live": ["proptype", "propertytype"],
        "homestead_flag_live": ["homestead", "homesteadflag"],
        "cad_zoning_live": ["cad_zoning", "zoning"],
    }.items():
        coalesce_column(target, denton, candidates)

